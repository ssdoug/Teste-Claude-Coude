---
// Página privada, atrás do Cloudflare Access (aplicação Self-hosted em /lab).
// Autocontida como as demais páginas do site (sem layout compartilhado) —
// não importa src/styles/global.css, segue o padrão de index.astro/oferta1.astro.
const title = 'Lab — IA Lab';
---

<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<a href="/" class="logo">IA Lab</a>
			<span class="tag">lab privado</span>
		</header>

		<main>
			<h1>Lab</h1>
			<p class="subtitle">Converse direto com o backend em <code>/api/chat</code>.</p>

			<textarea id="prompt" rows="5" placeholder="Escreva seu prompt..."></textarea>
			<button id="send">Enviar</button>

			<pre id="out"></pre>
		</main>

		<script>
			const btn = document.getElementById('send') as HTMLButtonElement;
			const out = document.getElementById('out') as HTMLElement;
			const promptEl = document.getElementById('prompt') as HTMLTextAreaElement;

			btn.addEventListener('click', async () => {
				const prompt = promptEl.value.trim();
				if (!prompt) return;

				btn.disabled = true;
				out.textContent = 'Pensando...';

				try {
					const res = await fetch('/api/chat', {
						method: 'POST',
						headers: { 'content-type': 'application/json' },
						body: JSON.stringify({ prompt }),
					});

					// Se a sessão do Access expirar, o fetch é redirecionado para a
					// tela de login (HTML) em vez de devolver JSON do backend.
					const contentType = res.headers.get('content-type') || '';
					if (!res.ok || !contentType.includes('application/json')) {
						out.textContent = 'Sessão expirada ou acesso negado. Recarregue a página para logar de novo.';
						return;
					}

					const data = await res.json();
					out.textContent = data.text ?? JSON.stringify(data, null, 2);
				} catch (e) {
					out.textContent = 'Erro na requisição: ' + e;
				} finally {
					btn.disabled = false;
				}
			});
		</script>

		<style>
			:root {
				--bg: #0f1117;
				--bg-alt: #161925;
				--text: #f4f4f5;
				--text-muted: #a1a1aa;
				--accent: #6366f1;
				--accent-light: #818cf8;
				--border: #232635;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			body {
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
				background: var(--bg);
				color: var(--text);
				line-height: 1.6;
				min-height: 100vh;
			}
			header {
				display: flex;
				align-items: center;
				gap: 12px;
				padding: 24px 8%;
				border-bottom: 1px solid var(--border);
			}
			.logo {
				font-weight: 700;
				font-size: 1.25rem;
				color: var(--accent-light);
				text-decoration: none;
			}
			.tag {
				font-size: 0.8rem;
				color: var(--text-muted);
				background: rgba(99, 102, 241, 0.12);
				border: 1px solid rgba(99, 102, 241, 0.3);
				padding: 3px 10px;
				border-radius: 999px;
			}
			main {
				max-width: 640px;
				margin: 0 auto;
				padding: 56px 24px 80px;
			}
			h1 {
				font-size: 2rem;
				font-weight: 800;
				margin-bottom: 8px;
			}
			.subtitle {
				color: var(--text-muted);
				margin-bottom: 28px;
			}
			.subtitle code {
				background: rgba(255, 255, 255, 0.08);
				padding: 2px 6px;
				border-radius: 4px;
				font-size: 0.9em;
			}
			textarea {
				width: 100%;
				resize: vertical;
				background: var(--bg-alt);
				color: var(--text);
				border: 1px solid var(--border);
				border-radius: 10px;
				padding: 14px;
				font-size: 0.95rem;
				font-family: inherit;
				margin-bottom: 14px;
			}
			textarea:focus {
				outline: none;
				border-color: var(--accent);
			}
			button {
				background: var(--accent);
				color: white;
				border: none;
				border-radius: 8px;
				padding: 12px 26px;
				font-weight: 600;
				font-size: 0.95rem;
				cursor: pointer;
				transition: opacity 0.15s;
			}
			button:hover { opacity: 0.9; }
			button:disabled { opacity: 0.5; cursor: default; }
			pre {
				white-space: pre-wrap;
				word-break: break-word;
				margin-top: 24px;
				padding: 18px;
				background: var(--bg-alt);
				border: 1px solid var(--border);
				border-radius: 10px;
				min-height: 1.6em;
				color: var(--text);
				font-family: inherit;
			}
		</style>
	</body>
</html>
